# /etc/pam.d/aetherlock

# 1. التحقق من كلمة المرور عبر النظام الأساسي
auth        include     system-auth

# 2. أخذ كلمة المرور التي تم إدخالها للتو وتمريرها للمحفظة لفك تشفيرها!
auth        optional    pam_gnome_keyring.so

# 3. إعدادات الحساب والجلسات القياسية
account     include     system-auth
password    include     system-auth
session     include     system-auth